NODE_ENV=development
PORT=3000

# Frontend / CORS
FRONTEND_DOMAIN_NOT_SECURE=http://safetysense.team
FRONTEND_DOMAIN_SECURE=https://www.safetysense.team
FRONTEND_LOCAL=http://localhost:5173
MOBILE_APP=http://localhost:5173
DOMAIN=localhost

# Database / Neon Postgres
# Paste Neon's pooled connection string here. Keep sslmode=require.
DATABASE_URL=postgresql://neondb_owner:npg_hple9swf3oRH@ep-floral-tree-aompyul1-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DB_SSL=true

# Optional fallback if DATABASE_URL is not set.
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# Redis / Upstash
# Paste Upstash's Redis URL here, usually rediss://default:<password>@<host>:6379
REDIS_URL="rediss://default:gQAAAAAAAkX1AAIgcDJlMzNjOTRlOTNiZjQ0NGQ1OWNhNzU0Y2UzMTQ2NDk4Mw@composed-falcon-148981.upstash.io:6379"

# Optional fallback if REDIS_URL is not set.
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=3
RATE_LIMIT_MESSAGE=Too many login attempts. Please try again later.

# Auth
JWT_SECRET=local-dev-jwt-secret-change-before-deploying
JWT_EXPIRES_IN=15m
REFRESH_SECRET=local-dev-refresh-secret-change-before-deploying
REFRESH_EXPIRES_IN=7d
API_KEY=local-dev-camera-api-key

# File storage
# Use local for offline development, or supabase for hosted object storage.
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=uploads
BACKEND_PUBLIC_URL=http://localhost:3000

# Supabase storage. Required only when STORAGE_DRIVER=supabase.
SB_PROJECT_URL=
SB_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# Email. Required only when sending verification/reset/status emails.
EMAIL_USER=johnpauldanmachi@gmail.com
EMAIL_PASSWORD="fuwi yqwt xsfx iecq"

# Firebase Cloud Messaging
RESPONDER_TOPIC=all_responders
