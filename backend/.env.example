NODE_ENV=development
PORT=3000

# Frontend / CORS
FRONTEND_DOMAIN_NOT_SECURE=http://safetysense.team
FRONTEND_DOMAIN_SECURE=https://www.safetysense.team
FRONTEND_LOCAL=http://localhost:5173
MOBILE_APP=http://localhost:5173
DOMAIN=localhost

# Database / Neon Postgres
# Neon dashboard -> Connection Details -> pooled connection string.
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require
DB_SSL=true

# Optional fallback if DATABASE_URL is not set.
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# Redis / Upstash
# Upstash dashboard -> Redis database -> Connect -> Redis URL.
REDIS_URL=rediss://default:password@example.upstash.io:6379

# Optional fallback if REDIS_URL is not set.
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=3
RATE_LIMIT_MESSAGE=Too many login attempts. Please try again later.

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_SECRET=replace-with-a-different-long-random-secret
REFRESH_EXPIRES_IN=7d
API_KEY=replace-with-camera-api-key

# File storage
# Use local for offline development, or supabase for hosted object storage.
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=uploads
BACKEND_PUBLIC_URL=http://localhost:3000

# Supabase storage. Required only when STORAGE_DRIVER=supabase.
SB_PROJECT_URL=https://your-project.supabase.co
SB_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=uploads

# Email. Required for verification/reset/status emails.
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Firebase Cloud Messaging
RESPONDER_TOPIC=all_responders


